{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "declaration": true,
      "emitDeclarationOnly": true,
      "allowJs": true,
      "checkJs": false,
      "outDir": "./dist/types",
      "moduleResolution": "Node",
      "skipLibCheck": true
    },
    "include": ["src/**/*.js"],
    "exclude": ["tests", "dist"]
  }